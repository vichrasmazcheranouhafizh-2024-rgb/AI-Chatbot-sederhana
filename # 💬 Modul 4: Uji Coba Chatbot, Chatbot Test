import markdown
from IPython.display import display, HTML
from google.colab import output

# -------------------------------------------------------------------------
# 1. MAGIC AREA: Fungsi Render Gelembung Chat (HTML/CSS + Markdown Parser)
# -------------------------------------------------------------------------
def tampilkan_chat_profesional(pengirim, pesan, is_user=False):
    if is_user:
        # User: Hijau (sebelah kanan)
        warna_bg = "#dcf8c6"
        margin = "margin-left: auto; margin-right: 0;"
    else:
        # Bot: Abu-abu (sebelah kiri)
        warna_bg = "#f1f0f0"
        margin = "margin-right: auto; margin-left: 0;"

    # A. Mengubah Markdown Gemini (misal: **bold**) menjadi HTML asli (misal: <strong>bold</strong>)
    pesan_html = markdown.markdown(pesan)

    # B. Escape kutip tunggal dalam string HTML untuk JavaScript
    pesan_escaped = pesan_html.replace("'", "\\'")

    # C. Membuat template HTML untuk pesan tunggal
    bubble_html = f"""
    <div class="message_bubble" style="background-color: {warna_bg}; padding: 12px 18px; border-radius: 15px; width: fit-content; max-width: 80%; {margin} box-shadow: 0px 2px 5px rgba(0,0,0,0.1); color: black;">
        <b style="font-size: 0.85em; color: #555;">{pengirim}</b><br>
        <div style="font-size: 1em; line-height: 1.5; margin-top: 5px;">{pesan_escaped}</div>
    </div>
    """

    # D. Injeksi gelembung pesan baru ke dalam kontainer 'chat_history' di UI Frame
    output.eval_js(f"document.getElementById('chat_history').innerHTML += '{bubble_html.replace('\n', '')}';")
    # Otomatis scroll ke bawah
    output.eval_js("var objDiv = document.getElementById('chat_area'); objDiv.scrollTop = objDiv.scrollHeight;")

